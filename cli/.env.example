# Path to the SQLite database created by the server package.
# Relative to the cli/ directory when running via pnpm --filter vetor-wallet-cli.
# For future Turso migration: DATABASE_URL=libsql://your-db.turso.io?authToken=...
DATABASE_URL=file:../server/data/wallet.db

# brapi.dev token (optional — higher rate limit with a token)
BRAPI_TOKEN=
